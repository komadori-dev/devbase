{
    "name": "DevBase Python Test Dev Container",
    "dockerComposeFile": [
        "../docker-compose.yml",
        "docker-compose.override.yml"
    ],
    "service": "python-example-dev",
    "workspaceFolder": "/workspace/python-example",
    "containerEnv": {
        "DEVBASE_PRESETS": "python",
        "DEVBASE_HOOKS_DIR": "/workspace/python-example/.devcontainer"
    },
    "postAttachCommand": "terminal",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
                "terminal.integrated.fontSize": 13
            },
            "extensions": [
                "ms-azuretools.vscode-containers"
            ]
        }
    }
}