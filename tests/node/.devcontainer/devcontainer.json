{
    "name": "DevBase Node Test Dev Container",
    "dockerComposeFile": [
        "../docker-compose.yml",
        "docker-compose.override.yml"
    ],
    "service": "node-example-dev",
    "workspaceFolder": "/workspace/node-example",
    "containerEnv": {
        "DEVBASE_PRESETS": "node",
        "DEVBASE_NO_MENU": "1"
    },
    "postAttachCommand": "terminal 2>&1 | tee -a /tmp/devbase-ci.log",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
                "terminal.integrated.fontSize": 13
            },
            "extensions": [
                "ms-azuretools.vscode-containers"
            ]
        }
    }
}
